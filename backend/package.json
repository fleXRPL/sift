{
  "name": "sift-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "package": "npm run build && pkg package.json --no-bytecode --public --public-packages \"*\" --output ../src-tauri/binaries/sift-backend-x86_64-pc-windows-msvc",
    "package:mac-arm": "npm run build && pkg package.json --no-bytecode --public --public-packages \"*\" --target node18-macos-arm64 --output ../src-tauri/binaries/sift-backend-aarch64-apple-darwin",
    "package:mac-x64": "npm run build && pkg package.json --no-bytecode --public --public-packages \"*\" --target node18-macos-x64 --output ../src-tauri/binaries/sift-backend-x86_64-apple-darwin"
  },
  "pkg": {
    "assets": [
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/better-sqlite3/prebuilds/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "../src-tauri/binaries"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@yao-pkg/pkg": "^6.19.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
